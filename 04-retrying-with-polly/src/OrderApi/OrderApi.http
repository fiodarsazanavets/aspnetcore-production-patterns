@host = https://localhost:7180

### Inject two transient shipping failures
POST {{host}}/diagnostics/faults
Content-Type: application/json

{
  "shippingDelayMs": 0,
  "shippingUnavailable": false,
  "forceReadinessFailure": false,
  "shippingTransientFailuresBeforeSuccess": 2
}

### Create order - succeeds after retries
POST {{host}}/orders
Content-Type: application/json
Idempotency-Key: retry-demo-001

{
  "customerId": "f6e92b94-4967-4e5c-b78f-734f88d8673d",
  "lines": [
    {
      "sku": "COURSE-001",
      "quantity": 2
    }
  ]
}

### Inject too many transient shipping failures
POST {{host}}/diagnostics/faults
Content-Type: application/json

{
  "shippingDelayMs": 0,
  "shippingUnavailable": false,
  "forceReadinessFailure": false,
  "shippingTransientFailuresBeforeSuccess": 10
}

### Create order - fails after retry attempts
POST {{host}}/orders
Content-Type: application/json
Idempotency-Key: retry-demo-002

{
  "customerId": "f6e92b94-4967-4e5c-b78f-734f88d8673d",
  "lines": [
    {
      "sku": "COURSE-001",
      "quantity": 2
    }
  ]
}